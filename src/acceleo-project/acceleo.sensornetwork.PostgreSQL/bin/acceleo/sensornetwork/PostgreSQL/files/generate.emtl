    <ownedModuleElement xsi:type="mtl:Template" name="generateSchema" visibility="Public" main="true">
      <body xsi:type="mtl:TemplateInvocation" definition="/0/generateSQLContent">
        <eType xsi:type="ocl.ecore:PrimitiveType" href="http://www.eclipse.org/ocl/1.1.0/oclstdlib.ecore#/0/String"/>
